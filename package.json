{
  "name": "neo-agent",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "start": "npx tsx packages/tui/src/cli.ts",
    "db:generate": "pnpm --filter @neo-agent/memory exec drizzle-kit generate",
    "db:migrate": "pnpm --filter @neo-agent/memory exec drizzle-kit migrate"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "tsx": "^4.0.0",
    "drizzle-kit": "^0.30.0",
    "@types/better-sqlite3": "^7.0.0"
  },
  "packageManager": "pnpm@9.15.4"
}
